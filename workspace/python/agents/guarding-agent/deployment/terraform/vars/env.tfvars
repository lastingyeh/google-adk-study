# 用於資源命名的專案名稱
project_name = "guarding-agent"

# 您的生產環境 (Production) Google Cloud 專案 ID
prod_project_id = "your-production-project-id"

# 您的測試環境 (Staging) Google Cloud 專案 ID
staging_project_id = "your-staging-project-id"

# 將用於託管 Cloud Build 流水線的 Google Cloud 專案 ID
cicd_runner_project_id = "your-cicd-project-id"

# 您在 Cloud Build 中建立的主機連線名稱
host_connection_name = "git-guarding-agent"

# 儲存在 Secret Manager 中的 GitHub PAT 密鑰 ID
github_pat_secret_id = "your-github_pat_secret_id"

# GitHub 組織或使用者名稱
repository_owner = "Your GitHub organization or username."

# 您新增至 Cloud Build 的儲存庫名稱
repository_name = "guarding-agent"

# 您將用於部署基礎架構的 Google Cloud 區域
region = "us-central1"
