# Google AI API Key (Required)
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_api_key_here

# Or use Vertex AI (Alternative)
# GOOGLE_CLOUD_PROJECT=your_project_id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Logging Configuration
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR

# Security Configuration Path
SECURITY_CONFIG_PATH=config/security_config.yaml

# Content Filter Configuration Path
CONTENT_FILTER_CONFIG_PATH=config/security_config.yaml

# Application Settings
APP_NAME=guarding_agent
ENVIRONMENT=development  # development, staging, production

# Performance Monitoring (Optional)
ENABLE_METRICS=true
METRICS_EXPORT_INTERVAL=60

# Optional: BigQuery Integration (Phase 4)
# BIGQUERY_PROJECT_ID=your_project
# BIGQUERY_DATASET=adk_security
# BIGQUERY_TABLE=agent_logs
